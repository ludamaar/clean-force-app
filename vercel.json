{
  "rewrites": [
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/(.*)", "destination": "/index.html" },
    { "source": "/api/create-checkout", "destination": "/api/create-checkout.js" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/create-checkout.js": { "memory": 256, "maxDuration": 10 },
    "api/webhook.js": { "memory": 256, "maxDuration": 10 }
  }
}
